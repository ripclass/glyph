# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Identity layer (M3) — server-side only ===
# Master key for private-key-at-rest (AES-256-GCM). 32 bytes, base64:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# LOSING THIS KEY ORPHANS EVERY STORED PRIVATE KEY. Back it up.
CREDENTIAL_ENCRYPTION_KEY=base64-32-bytes
# The did:web host — every DID permanently embeds it.
# Production: khamhealth.com   Local: localhost:3000
DID_WEB_HOST=khamhealth.com

# === Google Cloud ===
GOOGLE_CLOUD_PROJECT_ID=your-project
GOOGLE_CLOUD_SPEECH_KEY=your-speech-key
GOOGLE_AI_STUDIO_KEY=your-ai-studio-key

# === OpenRouter (one key serving Gemini/Claude/Perplexity/OpenAI) ===
# Used by llm-router.ts as the transport whenever a provider's native key
# below is absent. Native keys always take precedence when set.
OPENROUTER_API_KEY=your-openrouter-key

# === Gemini (native; llm-router reads GEMINI_API_KEY, not GOOGLE_AI_STUDIO_KEY) ===
GEMINI_API_KEY=your-gemini-key

# === Anthropic ===
ANTHROPIC_API_KEY=your-claude-key

# === OpenAI ===
OPENAI_API_KEY=your-openai-key

# === Perplexity ===
PERPLEXITY_API_KEY=your-perplexity-key

# === UpToDate Connect ===
UPTODATE_API_KEY=your-uptodate-key
# Optional — consult-uptodate defaults to https://connect.uptodate.com
UPTODATE_BASE_URL=https://connect.uptodate.com

# === WhatsApp Business (send-followup reads WHATSAPP_ACCESS_TOKEN) ===
WHATSAPP_ACCESS_TOKEN=your-token
WHATSAPP_PHONE_NUMBER_ID=your-number-id

# === App ===
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_DEFAULT_LANGUAGE=bn
NEXT_PUBLIC_APP_NAME=Glyph
